<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Home Added</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    h1 {
      color: #28a745;
      font-size: 2rem;
      margin-bottom: 20px;
    }

    p {
      font-size: 1.2rem;
      color: #555;
      margin-bottom: 30px;
      padding: 15px;
      background: #f8f9fa;
      border-radius: 10px;
      border-left: 4px solid #28a745;
    }
  </style>
</head>

<body>
  <%- include('partials/header') %>
    <div class="container">
      <h1>Home added successfully!</h1>
      <p>Home Name: <%= name %>
      </p>
      <p>Location: <%= location %>
      </p>
      <p>Price per night: $<%= price %>
      </p>
      <a href="/" class="btn">Go back to Home</a>
    </div>
</body>

</html>