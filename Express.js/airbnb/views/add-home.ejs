<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Home - Airbnb</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <%- include('partials/header') %>
    <main>
      <div class="form-container">
        <h1 class="page-title" style="margin-top: 0;">Add your home</h1>
        <form action="/host/add-home" method="POST" enctype="multipart/form-data" >
          <div class="form-group">
            <label for="name">Home Name</label>
            <input type="text" id="name" name="name" class="form-control" placeholder="e.g. Cozy Cabin in the Woods" required />
          </div>
          
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" class="form-control" placeholder="e.g. Aspen, Colorado" required />
          </div>
          
          <div class="form-group">
            <label for="price">Price per night ($)</label>
            <input type="number" id="price" name="price" class="form-control" placeholder="e.g. 150" required />
          </div>

          <div>
            <label for="image">Image</label>
            <input type="file" id="image" name="image" class="form-control" accept="image/png, image/jpeg, image/jpg" required />
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Add Home</button>
        </form>
      </div>
    </main>
  </body>
</html>