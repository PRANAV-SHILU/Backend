<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Home - Airbnb</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <%- include('partials/header') %>
    <main>
      <div class="form-container">
        <h1 class="page-title" style="margin-top: 0;">Edit your home</h1>
        <form action="/host/edit-home/<%= home._id %>" method="POST">
          <div class="form-group">
            <label for="name">Home Name</label>
            <input type="text" id="name" name="name" class="form-control" value="<%= home.name %>" required />
          </div>
          
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" class="form-control" value="<%= home.location %>" required />
          </div>
          
          <div class="form-group">
            <label for="price">Price per night ($)</label>
            <input type="number" id="price" name="price" class="form-control" value="<%= home.price %>" required />
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Save Changes</button>
        </form>
      </div>
    </main>
  </body>
</html>