<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Home - Airbnb</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <%- include('partials/header') %>
    <main>
      <div class="form-container">
        <h1 class="page-title" style="margin-top: 0;">Edit your home</h1>
        <form action="/host/edit-home/<%= home._id %>" method="POST" enctype="multipart/form-data">
          <div class="form-group">
            <label for="name">Home Name</label>
            <input type="text" id="name" name="name" class="form-control" value="<%= home.name %>" required />
          </div>
          
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" class="form-control" value="<%= home.location %>" required />
          </div>
          
          <div class="form-group">
            <label for="price">Price per night ($)</label>
            <input type="number" id="price" name="price" class="form-control" value="<%= home.price %>" required />
          </div>

          <div class="form-group">
            <label for="image">Image</label>

            <% if (home.image) { %>
              <!-- Current image preview -->
              <div style="margin-bottom: 12px;">
                <img id="imagePreview" src="<%= backendUrl + home.image %>" alt="<%= home.name %>"
                  style="width: 100%; height: 200px; object-fit: cover; border-radius: var(--radius-md); display: block;" />
                <p style="margin-top: 8px; font-size: 0.82rem; color: var(--text-muted);">
                  📁 Current file: <strong><%= home.image.split('/').pop() %></strong>
                </p>
              </div>
            <% } else { %>
              <img id="imagePreview" src="" alt="" style="display: none; width: 100%; height: 200px; object-fit: cover; border-radius: var(--radius-md); margin-bottom: 12px;" />
            <% } %>

            <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/jpg" class="form-control" />
            <p style="margin-top: 6px; font-size: 0.82rem; color: var(--text-muted);">Leave empty to keep the current image.</p>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Save Changes</button>
        </form>
      </div>
    </main>

    <script>
      // Live-preview the newly selected image before submitting
      document.getElementById('image').addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
          const preview = document.getElementById('imagePreview');
          preview.src = e.target.result;
          preview.style.display = 'block';
        };
        reader.readAsDataURL(file);
      });
    </script>