<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Airbnb</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('partials/header') %>

    <main>
      <div class="auth-container">
        <h1 class="page-title" style="margin-top: 0;">Welcome Back</h1>
        <p style="text-align: center; margin-bottom: 30px;">Please login to your account.</p>
        
        <form action="/auth/login" method="POST">
          <div class="form-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" class="form-control" required />
          </div>
          
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" class="form-control" required />
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Log in</button>
        </form>

        <div style="text-align: center; margin-top: 30px;">
            <p>Don't have an account? <a href="/auth/register">Sign up</a></p>
        </div>
      </div>
    </main>
  </body>
</html>
