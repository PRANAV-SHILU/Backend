<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favourites - Airbnb</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <main>
        <div class="container">
            <h1 class="page-title">Your Favourite Homes</h1>
            
            <% if (homes.length === 0) { %>
                <div class="empty-state">
                  <h3>No favorites yet!</h3>
                  <p>Browse homes and tap the heart icon to save them here.</p>
                  <a href="/" class="btn btn-primary">Explore Homes</a>
                </div>
            <% } else { %>
                <div class="properties-grid">
                    <% homes.forEach(home => { %>
                        <div class="property-card">
                            <div class="property-card-content">
                                <div class="property-card-title-row">
                                  <h3 class="property-card-title"><%= home.name %></h3>
                                </div>
                                <p class="property-card-location">📍 <%= home.location %></p>
                                <div class="property-card-price">$<%= home.price %> <span style="font-size:0.8rem; font-weight:normal;">/ night</span></div>
                            </div>
                            
                            <div class="property-card-actions">
                                <a href="/homes/<%=home._id%>" class="btn btn-primary" style="flex: 1; text-align: center;">View Details</a>
                                <button onclick="removeFromFavourites('<%= home._id %>')"
                                        class="btn btn-sm"
                                        style="background-color: var(--error); color: white; border: none; cursor: pointer;"
                                        title="Remove from favourites">
                                  🗑️ Remove
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
                
                <div style="margin-top: 40px; text-align: center;">
                    <a href="/" class="btn btn-outline">Back To Home</a>
                </div>
            <% } %>
        </div>
    </main>

    <script>
      async function removeFromFavourites(homeId) {
        if (!confirm("Remove this home from your favourites?")) return;
        try {
          const res = await fetch(`/favourites/${homeId}`, { method: "DELETE" });
          if (res.ok) {
            location.reload();
          } else {
            alert("Failed to remove from favourites");
          }
        } catch (err) {
          console.error("Error removing favourite:", err);
          alert("An error occurred");
        }
      }
    </script>
</body>
</html>